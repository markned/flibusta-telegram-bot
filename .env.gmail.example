# Gmail SMTP template for private/family Kindle sending.
# Copy into .env and fill secrets on the server only.

SMTP_PROVIDER=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your.dedicated.gmail@gmail.com
SMTP_PASSWORD=your-google-app-password
SMTP_FROM_EMAIL=your.dedicated.gmail@gmail.com
SMTP_STARTTLS=true
SMTP_CUSTOM_DOMAIN=
SMTP_DNS_CHECKS_ENABLED=false

KINDLE_MAX_ATTACHMENT_MB=28
KINDLE_DEFAULT_FORMAT=epub
KINDLE_SEND_RATE_LIMIT_PER_HOUR=5
KINDLE_WORKER_CONCURRENCY=1
KINDLE_USER_CONCURRENCY=1
KINDLE_ENABLE_CONVERSION=false
KINDLE_CONVERSION_TARGET_FORMAT=epub
KINDLE_MAX_JOB_ATTEMPTS=3
KINDLE_RETRY_BASE_DELAY_SECONDS=10
KINDLE_DELIVERY_LOG_RETENTION_DAYS=90
KINDLE_METADATA_POLISH_ENABLED=true
KINDLE_METADATA_REQUIRE_CALIBRE=false
KINDLE_METADATA_TOOL=ebook-meta
KINDLE_METADATA_TIMEOUT_SECONDS=30
KINDLE_EMBED_COVER_ENABLED=true
KINDLE_FILENAME_TEMPLATE="{author} - {title}"
KINDLE_STRICT_METADATA_TITLE_AUTHOR=true


BOOK_COVER_UI_ENABLED=true
BOOK_COVER_SEND_AS_PHOTO=true
BOOK_COVER_FALLBACK_TO_TEXT=true
COVER_CARD_CAPTION_MAX_CHARS=900
COVER_LOOKUP_ENABLED=true
COVER_PROVIDER_ORDER=flibusta,openlibrary,google_books
COVER_LOOKUP_TIMEOUT_SECONDS=6
COVER_CACHE_TTL_SECONDS=604800
COVER_NEGATIVE_CACHE_TTL_SECONDS=86400
COVER_MAX_DOWNLOAD_MB=3
COVER_MIN_WIDTH=300
COVER_MIN_HEIGHT=400
COVER_MIN_CONFIDENCE=0.72
GOOGLE_BOOKS_API_KEY=
